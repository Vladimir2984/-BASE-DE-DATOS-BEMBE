# Variables de entorno para BEMBE Server
# Copiar este archivo a .env y completar con valores reales

# Puerto del servidor
PORT=3000

# JWT Secret (cambiar por valor aleatorio seguro)
JWT_SECRET=cambiar_esto_por_un_secreto_muy_seguro_2026

# Supabase Configuration
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-clave-anonima-de-supabase
SUPABASE_SERVICE_ROLE_KEY=tu-clave-service-role-de-supabase

# Encryption
ENCRYPTION_KEY=cambiar_esto_por_clave_encriptacion_2026

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Node Environment
NODE_ENV=production
