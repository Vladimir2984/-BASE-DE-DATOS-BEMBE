{
"mcpServers": {
    "playwright": {
        "command": "npx",
        "args": [
            "@playwright/mcp@latest"
        ]
    },
    "code-security": {
        "command": "npx",
        "args": [
            "-y",
            "@baidusecurity/code-security"
        ],
        "timeout": 300
    },
    "everything-search": {
        "command": "uvx",
        "args": [
            "mcp-server-everything-search"
        ]
    },
    "fetch": {
        "command": "uvx",
        "args": [
            "mcp-server-fetch"
        ]
    },
    "sequential-thinking": {
        "command": "npx",
        "args": [
            "-y",
            "@modelcontextprotocol/server-sequential-thinking"
        ]
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {}
    }
    "mcpServers": {
        "filesystem": {
           "command": "npx",
        "args": [
            "-y",
            "@modelcontextprotocol/server-filesystem"
        ]        }
    }
  }
}